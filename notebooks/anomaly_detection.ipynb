   "source": [
    "import pandas as pd\n",
    "from sklearn.ensemble import IsolationForest\n",
    "\n",
    "df = pd.read_csv(\"../data/ecommerce_data.csv\")\n",
    "\n",
    "X = df[['price','quantity','revenue']]\n",
    "\n",
    "model = IsolationForest()\n",
    "\n",
    "model.fit(X)\n",
    "\n",
    "\n",
    "df[\"anomaly\"] = model.predict(X)\n",
    "\n",
    "df.head()"
   ]
  },
